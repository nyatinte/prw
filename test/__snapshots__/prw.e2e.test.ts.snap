exports[`prw e2e > shows help when --help is passed 1`] = `
"
Interactive pnpm workspace package & script runner (prw v0.0.0-test)

USAGE prw [OPTIONS] [PACKAGE] [SCRIPT]

ARGUMENTS

  PACKAGE    Package name or fuzzy search query
   SCRIPT    Script name to run in the selected package

OPTIONS

     -h, --help    Show help
  -v, --version    Show version number"
`;

