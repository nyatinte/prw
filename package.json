{
  "name": "@nyatinte/prw",
  "version": "0.4.2",
  "description": "Interactive pnpm workspace package & script runner",
  "keywords": [
    "cli",
    "pnpm",
    "workspace"
  ],
  "homepage": "https://github.com/nyatinte/prw#readme",
  "bugs": {
    "url": "https://github.com/nyatinte/prw/issues"
  },
  "license": "MIT",
  "author": "nyatinte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyatinte/prw.git"
  },
  "man": [
    "./man/prw.1"
  ],
  "bin": {
    "prw": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "man"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "clean:dist": "rm -rf dist",
    "build:man": "marked-man man/prw.1.md -o man/prw.1",
    "changeset": "changeset",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "knip": "knip",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm build && pnpm build:man",
    "release": "changeset publish",
    "test": "pnpm build && vitest",
    "test:run": "pnpm build && vitest run",
    "test:coverage": "pnpm build && vitest run --coverage",
    "test:update": "pnpm build && vitest -u",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@clack/prompts": "1.3.0",
    "citty": "0.2.2",
    "picocolors": "1.1.1",
    "tinyglobby": "0.2.16",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260430.1",
    "@vitest/coverage-v8": "4.1.5",
    "fs-fixture": "2.13.0",
    "knip": "6.9.0",
    "lefthook": "2.1.6",
    "marked-man": "2.1.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsdown": "0.21.10",
    "tuistory": "0.3.0",
    "ultracite": "7.6.2",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=24.14.0",
    "pnpm": "10.30.3"
  },
  "packageManager": "pnpm@10.30.3"
}
