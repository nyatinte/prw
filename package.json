{
  "name": "@nyatinte/prw",
  "version": "0.0.1",
  "description": "Interactive pnpm workspace package & script runner",
  "type": "module",
  "main": "./dist/index.mjs",
  "bin": "./dist/bin.mjs",
  "scripts": {
    "build": "tsdown",
    "test": "vitest",
    "prepublishOnly": "pnpm build",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "keywords": [
    "pnpm",
    "workspace",
    "cli"
  ],
  "author": "nyatinte",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "lefthook": "^2.1.2",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "ultracite": "7.2.4",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.1",
    "picocolors": "^1.1.1"
  }
}
