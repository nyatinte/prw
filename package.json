{
  "name": "@nyatinte/prw",
  "version": "0.4.1",
  "description": "Interactive pnpm workspace package & script runner",
  "keywords": [
    "cli",
    "pnpm",
    "workspace"
  ],
  "homepage": "https://github.com/nyatinte/prw#readme",
  "bugs": {
    "url": "https://github.com/nyatinte/prw/issues"
  },
  "license": "MIT",
  "author": "nyatinte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyatinte/prw.git"
  },
  "man": [
    "./man/prw.1"
  ],
  "bin": {
    "prw": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "man"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "clean:dist": "rm -rf dist",
    "build:man": "marked-man man/prw.1.md -o man/prw.1",
    "changeset": "changeset",
    "check": "vp check",
    "fix": "vp check --fix",
    "knip": "knip",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm build && pnpm build:man",
    "release": "changeset publish",
    "test": "pnpm build && vp test",
    "test:run": "pnpm build && vp test run",
    "test:coverage": "pnpm build && vp test run --coverage",
    "test:update": "pnpm build && vp test -u",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "citty": "0.2.1",
    "picocolors": "1.1.1",
    "tinyglobby": "0.2.15",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/node": "24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "@vitest/coverage-v8": "4.1.0",
    "fs-fixture": "2.11.0",
    "jsonc-parser": "3.3.1",
    "knip": "5.86.0",
    "lefthook": "2.1.4",
    "marked-man": "2.1.0",
    "tuistory": "0.0.16",
    "typescript": "5.9.3",
    "ultracite": "7.3.0",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.14.0",
    "pnpm": "10.30.3"
  },
  "packageManager": "pnpm@10.30.3"
}
